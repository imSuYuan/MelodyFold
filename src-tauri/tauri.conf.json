{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "音折",
  "version": "0.1.0",
  "identifier": "com.yinzhe.music",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "音折",
        "width": 400,
        "height": 760,
        "minWidth": 360,
        "minHeight": 600,
        "maxWidth": 1200,
        "maxHeight": 900,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
